{
  "name": "creafly-droneclassroom",
  "private": true,
  "version": "2.0.0",
  "description": "CREAFLY 教室版無人機模擬器（Babylon.js + TypeScript monorepo）",
  "scripts": {
    "dev": "pnpm --parallel --filter @creafly/simulator --filter @creafly/teacher --filter @creafly/api dev",
    "dev:sim": "pnpm --filter @creafly/simulator dev",
    "dev:api": "pnpm --filter @creafly/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "legacy": "node legacy/server.js"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@10.32.0"
}
